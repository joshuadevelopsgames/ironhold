{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": "gui",
        "model": {
          "type": "minecraft:model",
          "model": "ironhold:item/pitchfork"
        }
      },
      {
        "when": "ground",
        "model": {
          "type": "minecraft:model",
          "model": "ironhold:item/pitchfork"
        }
      },
      {
        "when": "fixed",
        "model": {
          "type": "minecraft:model",
          "model": "ironhold:item/pitchfork"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:special",
      "base": "ironhold:item/pitchfork",
      "model": {
        "type": "geckolib:geckolib"
      }
    }
  }
}
